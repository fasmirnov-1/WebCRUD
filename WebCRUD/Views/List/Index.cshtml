@model IEnumerable<WebCRUD.Models.MaterialRecord>

@{
    string html = null;

    if (Model == null)
    {
        html = "<tr><td colspan='6' class='stub'>Нет данных...</td></tr>";
    }
    else
    {
        for (int i = 0; i < Model.ToArray().Count(); i++)
        {
            html = "<tr><td>@Model.ToArray()[i]</td></tr>";
        }
    }
}

<div class="screen">
    <table id="lst" class="screen">
        <tr>
            <td id="lst_records" class="list">
                <table id="list_header" class="screen" style="border: 1px solid black;">
                    <thead>
                        <tr>
                            <th>
                                ИД материала
                            </th>
                            <th>
                                Тайм код материала
                            </th>
                            <th>
                                Дата эфира
                            </th>
                            <th>
                                Наименование материала
                            </th>
                            <th>
                                Жанр материала
                            </th>
                            <th>
                                Рйтинг
                            </th>
                        </tr>
                    </thead>
                    <tbody id="bdy">
                        @Html.Raw(html)
                    </tbody>
                </table>
            </td>
            <td style="vertical-align: top;">
                <table id="panel_area" class="screen">
                    <tr>
                        <td style="vertical-align: top;">
                            <table id="add" style="width: 100%; border: 1px solid black; cursor: pointer;" onclick="OpenWindow()">
                                <tr>
                                    <td style="text-align: right;">
                                        <img style="width: 50px; height: 50px;" src="~/Images/Add.png" />
                                    </td>
                                    <td style=" text-align: left;">
                                        Добавить...
                                    </td>
                                </tr>
                            </table>
                        </td>
                        </tr>
                        <tr>
                        <td>
                            <table id="edit" style="width: 100%; border: 1px solid black; cursor: pointer;">
                                <tr>
                                    <td style="text-align: right;">
                                        <img style="width: 50px; height: 50px;" src="~/Images/pen.png" />
                                    </td>
                                    <td style=" text-align: left;">
                                        Изменить...
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                    <tr>
                        <td>
                            <table id="delete" style="width: 100%; border: 1px solid black; cursor: pointer;">
                                <tr>
                                    <td style="text-align: right;">
                                        <img style="width: 50px; height: 50px;" src="~/Images/remove.png" />
                                    </td>
                                    <td style=" text-align: left;">
                                        Удалить...
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</div>
